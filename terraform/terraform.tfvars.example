# Copy this to terraform.tfvars and fill in your actual values
# WARNING: Never commit terraform.tfvars — it contains real credentials!

# Google Cloud
project_id = "your-gcp-project-id"
region     = "us-central1"

# MongoDB
mongodb_connection_string = "mongodb+srv://user:pass@cluster.mongodb.net"
mongodb_database_name     = "ptc"

# JWT secret for WebAuthn sessions
jwt_secret = "your-secure-random-secret"

# Container image tag (CI sets this to commit SHA; use "latest" locally)
container_image_tag = "latest"

# GitHub OAuth
github_client_id     = "your-github-oauth-client-id"
github_client_secret = "your-github-oauth-client-secret"
github_redirect_uri  = "https://lifepete.com/settings?github=callback"

# Domains
api_domain = "api.example.com"

# Cloudflare
cloudflare_api_token = "your-cloudflare-api-token"
