# Beats API Configuration
# Server-side API URL (used by Express server routes)
API_URL=https://beats-api-145752321103.europe-west1.run.app

# Client-side API URL (used by React frontend)
# Note: Vite requires VITE_ prefix for client-side env vars
VITE_API_URL=https://beats-api-145752321103.europe-west1.run.app

# API token for POST/PUT/PATCH (must match backend ACCESS_TOKEN)
# Note: Vite requires VITE_ prefix for client-side env vars
VITE_API_TOKEN=secret
