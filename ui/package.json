{
  "name": "fusion-starter",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest --run",
    "lint": "biome check client/",
    "lint:fix": "biome check --write client/",
    "typecheck": "tsc",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "gen:openapi": "cd ../api && uv run python scripts/dump_openapi.py ../ui/client/shared/api/openapi.json",
    "gen:types": "pnpm gen:openapi && openapi-typescript client/shared/api/openapi.json -o client/shared/api/generated.ts",
    "gen:types:check": "pnpm gen:types && git diff --exit-code client/shared/api/openapi.json client/shared/api/generated.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.18",
    "@simplewebauthn/browser": "^13.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@playwright/test": "^1.61.1",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@swc/core": "^1.15.43",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.23.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.17.0+sha512.cca3cea332ad254bb84145f966d19f4879615210346fc92c79a047f23a0d7b3cca3c3792f0076ba1f1831d277efbcf0a9119b31a9a60eca7fb3d6231f331ef72"
}
